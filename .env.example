# Symfony
APP_ENV=dev
APP_SECRET=cambia_esto_por_un_valor_seguro

# Base de datos
DATABASE_URL=postgresql://cokalba:secret@postgres:5432/cokalba_running

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=cambia_esto
JWT_TTL=3600
JWT_REFRESH_TTL=86400

# Cloudflare R2 (S3 Compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
R2_BUCKET_NAME=cokalba-running
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# n8n Webhook (salida)
N8N_WEBHOOK_URL=https://n8n.dulziasalamanca.es/webhook/publicar-noticia
N8N_WEBHOOK_AUTH_HEADER=X-Autenticacion-Cokalba
N8N_WEBHOOK_AUTH_TOKEN=cambia_esto_por_un_token_alfanumerico_sin_caracteres_especiales

# n8n Callback (entrada)
N8N_CALLBACK_TOKEN=cambia_esto_por_token_secreto_aleatorio

# URL pública del sitio (para construir url_noticia)
APP_PUBLIC_URL=https://cokalba-running.com

# Mailer
MAILER_SENDER_EMAIL=cokalbarunning@gmail.com
MAILER_SENDER_NAME="Cokalba Running"

# Symfony Mailer DSN (requerido por el framework; los dorsales usan Brevo directamente)
MAILER_DSN=null://default

# Brevo (API v3) - usado para el envio de dorsales
BREVO_API_KEY=tu_api_key_de_brevo

# BCC para los emails de dorsales
MAILER_BCC_EMAIL=cokalbarunning@gmail.com

# Alternativa: Gmail SMTP (ya no se usa para dorsales)
# MAILER_DSN=smtps://cokalbarunning@gmail.com:PASSWORD@smtp.gmail.com:465

# Messenger transport (Redis)
MESSENGER_TRANSPORT_DSN=redis://shared-redis:6379/messages

# Frontend
VITE_API_URL=http://localhost:8080/api/v1

# Delay entre envios de emails de dorsales (segundos)
BIB_EMAIL_DELAY_SECONDS=3
